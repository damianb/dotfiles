diff --git a/symbols/pc b/symbols/pc
index 9f3da66..4bb6c02 100644
--- a/symbols/pc
+++ b/symbols/pc
@@ -80,8 +80,48 @@
     key  <END> {	[  End			]	};
     key <PGDN> {	[  Next			]	};

-    key   <UP> {	[  Up			]	};
-    key <LEFT> {	[  Left			]	};
-    key <DOWN> {	[  Down			]	};
-    key <RGHT> {	[  Right		]	};
+    key <UP> {
+        type="ARROW",
+        repeat=yes,
+        [ Up, Up, Prior, Up ],
+        actions[Group1] = [
+            NoAction(),
+            NoAction(),
+            RedirectKey(key=<PGUP>, clearmods=Alt),
+            NoAction()
+        ]
+    };
+    key <DOWN> {
+        type="ARROW",
+        repeat=yes,
+        [ Down, Down, Next, Down ],
+        actions[Group1] = [
+            NoAction(),
+            NoAction(),
+            RedirectKey(key=<PGDN>, clearmods=Alt),
+            NoAction()
+        ]
+    };
+    key <LEFT> {
+        type="ARROW",
+        repeat=yes,
+        [ Left, Left, Home, Left ],
+        actions[Group1] = [
+            NoAction(),
+            NoAction(),
+            RedirectKey(key=<HOME>, clearmods=Alt),
+            NoAction()
+        ]
+    };
+    key <RGHT> {
+        type="ARROW",
+        repeat=yes,
+        [ Right, Right, End, Right ],
+        actions[Group1] = [
+            NoAction(),
+            NoAction(),
+            RedirectKey(key=<END>, clearmods=Alt),
+            NoAction()
+        ]
+    };
 };
diff --git a/types/basic b/types/basic
index cf1ee64..a48e26c 100644
--- a/types/basic
+++ b/types/basic
@@ -4,6 +4,7 @@
     // three of the four required key types.
     // The fourth type "KEYPAD" is defined in the "numpad" file.

+    virtual_modifiers Alt;
     virtual_modifiers NumLock;

     type "ONE_LEVEL" {
@@ -27,4 +28,21 @@
     level_name[Level2] = "Caps";
     };

+    // Extra type for up and down arrow keys, which we modify to send
+    // Page Up and Page Down.
+    type "ARROW" {
+        modifiers              = Shift+Lock+Alt+Control;
+        map[Shift]             = Level2;
+        map[Lock]              = Level2;
+        map[Alt]               = Level3;
+        map[Alt+Shift]         = Level3;
+        map[Alt+Lock]          = Level3;
+        map[Control+Alt]       = Level4;
+        map[Control+Alt+Shift] = Level4;
+        map[Control+Alt+Lock]  = Level4;
+        level_name[Level1]     = "Base";
+        level_name[Level2]     = "Caps";
+        level_name[Level3]     = "Alt";
+        level_name[Level4]     = "ControlAlt";
+    };
 };


