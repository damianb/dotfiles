background yes
update_interval 1
update_interval_on_battery 3

cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius

double_buffer yes
no_buffers yes
text_buffer_size 2048

gap_x 30
gap_y 20
minimum_size 240 450
maximum_width 250
own_window yes
own_window_type desktop
own_window_argb_visual true
own_window_transparent yes
own_window_hints undecorate,sticky,skip_taskbar,skip_pager,below
border_inner_margin 0
border_outer_margin 0
alignment tr

draw_shades no
draw_outline no
draw_borders no
draw_graph_borders no

override_utf8_locale yes
use_xft yes
xftfont caviar dreams:size=8
xftalpha 0.5
uppercase no

default_color 666666
color1 999999
color2 B0B0B0
color3 D6D6D6
color4 CC3333

lua_load ~/conky_red.lua
lua_draw_hook_post main

TEXT
${voffset 11}
${goto 148}${color4}${font Droid Sans:size=14}${time %e}
${goto 149}${color2}${voffset -18}${font Ubuntu:size=8}${time %b}
${goto 145}${color2}${voffset -1}${font Ubuntu:size=8:weight=normal}${time %Y}${font}

${voffset 33}
${goto 90}${font Ubuntu:size=7:bold}${color}CPU ${font Ubuntu:size=7:weight=normal}${color1}${alignr}${loadavg}
${goto 90}${font Ubuntu:size=7:weight=normal}${color1}${top name 1}${alignr}${top cpu 1}%
${goto 90}${font Ubuntu:size=7:weight=normal}${color2}${top name 2}${alignr}${top cpu 2}%
${goto 90}${font Ubuntu:size=7:weight=normal}${color3}${top name 3}${alignr}${top cpu 3}%

${voffset 20}
${goto 90}${font Ubuntu:size=7:bold}${color}MEM ${font Ubuntu:size=7:weight=normal}${color1}${alignr}${mem} / ${memmax}
${goto 90}${font Ubuntu:size=7:weight=normal}${color1}${top_mem name 1}${alignr}${top_mem mem 1}%
${goto 90}${font Ubuntu:size=7:weight=normal}${color2}${top_mem name 2}${alignr}${top_mem mem 2}%
${goto 90}${font Ubuntu:size=7:weight=normal}${color3}${top_mem name 3}${alignr}${top_mem mem 3}%

${voffset 20}
${goto 90}${font Ubuntu:size=7:bold}${color}DISK ${font Ubuntu:size=7:weight=normal}${color1}${alignr}${diskio}
${goto 90}${font Ubuntu:size=7:weight=normal}${color1}used: ${fs_used /}${alignr} /

${voffset 46}
${goto 90}${font Ubuntu:size=7:bold}${color}BATTERY
${goto 90}${font Ubuntu:size=7:weight=normal}${color1}BAT0${alignr}${battery BAT0}
${goto 90}${font Ubuntu:size=7:weight=normal}${color1}EST:${alignr}${battery_time BAT0}