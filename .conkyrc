background yes
update_interval 1
update_interval_on_battery 3

cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius

double_buffer yes
no_buffers yes
text_buffer_size 2048

gap_x 5
gap_y 5
minimum_size 220 330
maximum_width 330
own_window yes
own_window_type override
own_window_transparent yes
own_window_hints undecorate,sticky,skip_taskbar,skip_pager,below
border_inner_margin 0
border_outer_margin 0
alignment tr

draw_shades no
draw_outline no
draw_borders no
draw_graph_borders no

override_utf8_locale yes
use_xft yes
xftfont caviar dreams:size=8
xftalpha 0.5
uppercase no

default_color 666666
color1 999999
color2 B0B0B0
color3 D6D6D6
color4 CC3333

lua_load ~/conky_red.lua
lua_draw_hook_post main

TEXT 
${goto 10}${font Droid Sans Mono Slashed:size=32}${color4}${time %H:%M:%S}${font}
${voffset 5}${alignr 40}${font Droid Sans:size=14}${color2}${time %b} ${time %e} ${time %Y}${font}

${voffset 15}
${goto 60}${font Ubuntu:size=7,weight:bold}${color}CPU ${goto 100}${font Ubuntu:size=7,weight:normal}${color1}${loadavg}
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}${top name 1}${alignr}${top cpu 1}%
${goto 60}${font Ubuntu:size=7,weight:normal}${color2}${top name 2}${alignr}${top cpu 2}%
${goto 60}${font Ubuntu:size=7,weight:normal}${color3}${top name 3}${alignr}${top cpu 3}%

${voffset 20}
${goto 60}${font Ubuntu:size=7,weight:bold}${color}MEM ${goto 100}${font Ubuntu:size=7,weight:normal}${color1}${mem} / ${memmax}
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}${top_mem name 1}${alignr}${top_mem mem 1}%
${goto 60}${font Ubuntu:size=7,weight:normal}${color2}${top_mem name 2}${alignr}${top_mem mem 2}%
${goto 60}${font Ubuntu:size=7,weight:normal}${color3}${top_mem name 3}${alignr}${top_mem mem 3}%

${voffset 20}
${goto 60}${font Ubuntu:size=7,weight:bold}${color}DISK ${goto 100}${font Ubuntu:size=7,weight:normal}${color1}${diskio}
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}used: ${fs_used /home} /home
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}used: ${fs_used /} /

${voffset 30}
${goto 60}${font Ubuntu:size=7,weight:bold}${color}BATTERY
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}BAT0${alignr}${battery BAT0}
${goto 60}${font Ubuntu:size=7,weight:normal}${color1}${alignr}${battery_time BAT0}
