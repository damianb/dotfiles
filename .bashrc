alias ll="ls -lAFh"

# web dev stuff reliant on nodejs
alias lessc="~/.npm/less/1.3.0/package/bin/lessc"
alias uglifyjs="~/.npm/uglify-js/1.2.6/package/bin/uglifyjs"

# minecraft overviewer
alias overviewer="overviewer.py --config ~/overviewer.conf --genpoi && overviewer.py --config ~/overviewer.conf"
